<IfModule mod_rewrite.c>
    RewriteEngine On

    # Hostinger serves the repository root. Forward every public request to
    # Laravel's public directory while keeping clean application URLs.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule mod_env.c>
    SetEnv APP_ENV production
    SetEnv APP_DEBUG false
</IfModule>
